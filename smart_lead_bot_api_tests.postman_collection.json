    {
      "name": "1. Signup Test User",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "pm.test(\"Status code is 200 or 400 (if already exists)\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);",
              "});",
              "if (pm.response.code === 200 && response.token) {",
              "    pm.environment.set(\"jwt_token\", response.token);",
              "    pm.test(\"Token received\", function () {",
              "        pm.expect(response.token).to.not.be.undefined;",
              "    });",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"testuser@smartleadbot.com\",\n  \"password\": \"smartpassword123\",\n  \"company\": \"Smart Testing Ltd\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/signup",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "signup"
          ]
        }
